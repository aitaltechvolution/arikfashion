# ──────────────────────────────────────────────────────────────
#  Arik Fashion – Environment Variables
#  Copy this file to .env and fill in your Supabase credentials.
#  Get these from: Supabase Dashboard → your project → Settings → API
# ──────────────────────────────────────────────────────────────

VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# ⚠️  Service role – never expose to the browser. Server-side / admin use only.
VITE_SUPABASE_SERVICE_ROLE=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
